---
---
<div class="container-idiomas">
  <div class="language-switcher">
    <button id="btn-es" class="lang-btn boder-especial-left">
     <img class="imagenSpanol" src="https://res.cloudinary.com/dlgeap8h0/image/upload/v1771217543/spanol_nisxya.png" alt="Español" />ES
    </button>
    <button id="btn-en" class="lang-btn boder-especial">
      <img class="imagenSpanol" src="https://res.cloudinary.com/dlgeap8h0/image/upload/v1771217543/eeuu_zp1ijv.png" alt="English" /> EN
    </button>
    <button id="btn-pr" class="boder-especial-right lang-btn">
      <img class="imagenSpanol" src="https://res.cloudinary.com/dlgeap8h0/image/upload/v1776789189/Flag_of_Brazil.svg_dcr2kp.png" alt="Português" /> PR
    </button>
  </div>
</div>

<style>

.container-idiomas{
    display: flex;
    margin-bottom: 30px;
    justify-content: center;
    align-items: center;

}


.lang-btn{
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
}

.imagenSpanol{
    width: 20px;
    height: 14px;
    border-radius: 3px;
}

.boder-especial-left{
  border-radius: 20px 0px 0px 20px !important;
}
.boder-especial-right{
  border-radius: 0px 20px 20px 0px !important;
}
.boder-especial{
  border-radius: 0px 0px 0px 0px  !important;
}
.language-switcher {
  display: flex;
  justify-content: center;
  align-items: center;
  width: 22%;
  margin-bottom: 20px;
}

@media (width < 48rem) {
.language-switcher {

  width: 80%;
  }
}
.lang-btn {
  border: none;
  padding: 8px 14px;
  border-radius: 20px;
  cursor: pointer;
  font-weight: bold;
  background: #eee;
  transition: all 0.3s ease;
}

.lang-btn.active {
  background: #28652b;
  color: white;
}

.lang-btn:hover {
  transform: scale(1.05);
}
</style>

<script is:inline>
  function setActive(lang) {
    document.querySelectorAll(".lang-btn").forEach(btn => btn.classList.remove("active"));
    const target = document.querySelector("#btn-" + lang);
    if (target) target.classList.add("active");
  }

  function changeLang(lang) {
    localStorage.setItem("lang", lang);
    setActive(lang);
    window.dispatchEvent(new CustomEvent("changeLang", { detail: lang }));
  }

  function initLangButtons() {
    if (window.__langInitialized) return;
    window.__langInitialized = true;

    const btnEs = document.getElementById("btn-es");
    const btnEn = document.getElementById("btn-en");
    const btnPr = document.getElementById("btn-pr");

    if (!btnEs || !btnEn || !btnPr) return;

    btnEs.addEventListener("click", function() { changeLang("es"); });
    btnEn.addEventListener("click", function() { changeLang("en"); });
    btnPr.addEventListener("click", function() { changeLang("pr"); });

    const savedLang = localStorage.getItem("lang") || "es";
    setActive(savedLang);

    setTimeout(function() {
      window.dispatchEvent(new CustomEvent("changeLang", { detail: savedLang }));
    }, 80);
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initLangButtons);
  } else {
    initLangButtons();
  }

  document.addEventListener("astro:page-load", function() {
    window.__langInitialized = false;
    initLangButtons();
  });
</script>