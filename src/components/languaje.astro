---

const banderaSpanol =
  "https://res.cloudinary.com/dlgeap8h0/image/upload/spanol_nisxya.webp";

const banderaEngland =
  "https://res.cloudinary.com/dlgeap8h0/image/upload/eeuu_zp1ijv.webp";
const currentPath = Astro.url.pathname;
const currentLocale = Astro.currentLocale || "es";
const isSpanish = currentLocale === "es";
const targetLocale = isSpanish ? "en" : "es";
const targetLabel = isSpanish ? "EN" : "ES";
const targetFlag = isSpanish ? banderaEngland : banderaSpanol;
const getTargetLink = () => {
  const cleanPath = currentPath.replace(/^\/en(\/|$)/, "/") || "/";
  return targetLocale === "en"
    ? `/en${cleanPath}`.replace(/\/+/g, "/")
    : cleanPath;
};


---
<div class="container-idiomas">
  <div class="language-switcher">
    <button id="btn-es" class="lang-btn">
      <img class="imagenSpanol" src="https://res.cloudinary.com/dlgeap8h0/image/upload/v1771217543/spanol_nisxya.webp" alt="Español" /> ES
    </button>
    <button id="btn-en" class="lang-btn">
      <img class="imagenSpanol" src="https://res.cloudinary.com/dlgeap8h0/image/upload/v1771217543/eeuu_zp1ijv.webp" alt="English" /> EN
    </button>
    <button id="btn-pr" class="lang-btn">
      <img class="imagenSpanol" src="https://res.cloudinary.com/dlgeap8h0/image/upload/v1776789189/Flag_of_Brazil.svg_dcr2kp.webp" alt="Português" /> PR
    </button>
  </div>
</div>

<style>

.container-idiomas{
    display: flex;
    margin-bottom: 30px;
    justify-content: center;
    align-items: center;

}


.lang-btn{
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
}

.imagenSpanol{
    width: 20px;
}

.language-switcher {
  display: flex;
  justify-content: flex-end;
  gap: 14px;
  width: 25%;
  margin-bottom: 20px;
}

.lang-btn {
  border: none;
  padding: 8px 14px;
  border-radius: 20px;
  cursor: pointer;
  font-weight: bold;
  background: #eee;
  transition: all 0.3s ease;
}

.lang-btn.active {
  background: #28652b;
  color: white;
}

.lang-btn:hover {
  transform: scale(1.05);
}
</style>

<script is:inline>
  function setActive(lang) {
    document.querySelectorAll(".lang-btn").forEach(btn => btn.classList.remove("active"));
    const target = document.querySelector(`#btn-${lang}`);
    if (target) target.classList.add("active");
  }

  function changeLang(lang) {
    localStorage.setItem("lang", lang);
    setActive(lang);
    window.dispatchEvent(new CustomEvent("changeLang", { detail: lang }));
  }

  document.addEventListener("DOMContentLoaded", () => {
    const savedLang = localStorage.getItem("lang") || "es";
    setActive(savedLang);
    window.dispatchEvent(new CustomEvent("changeLang", { detail: savedLang }));
  });

  document.getElementById("btn-es").addEventListener("click", () => changeLang("es"));
  document.getElementById("btn-en").addEventListener("click", () => changeLang("en"));
  document.getElementById("btn-pr").addEventListener("click", () => changeLang("pr"));
</script>