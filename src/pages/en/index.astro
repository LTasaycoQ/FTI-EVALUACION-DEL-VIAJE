<BaseLayout>
	<main>
		<Languaje />
		
		<section class="containerEvaluacionViaje">

			<div class="imagen-empresa">
				<img src="https://res.cloudinary.com/dlgeap8h0/image/upload/v1776726875/Group_22_vtvrk3.png" alt="Logo de la empresa" />
			</div>

			<div class="hero">
				<h1>TRIP EVALUATION</h1>
				<div class="hero-line"></div>
			</div>

			<div class="intro-card">
				<p>
					<strong>Dear visitor,</strong> We invite you to give us your opinion about our services. Please help us identify our employees who have done an excellent job so we can reward them and identify areas where we need to improve.
We strive to perfect the art of. <em> serving tourists</em>.
				</p>
			</div>

			<div class="containerForm">
