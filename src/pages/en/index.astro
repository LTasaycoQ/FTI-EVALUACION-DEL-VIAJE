				/>
			</div>

		</section>
	</main>
</BaseLayout>

<script is:inline src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script is:inline>
	document.querySelectorAll(".seccion-header").forEach((btn) => {
		btn.addEventListener("click", () => {
			const cuerpo = btn.nextElementSibling;
			const abierto = cuerpo.classList.contains("abierto");
			cuerpo.classList.toggle("abierto", !abierto);
			btn.setAttribute("aria-expanded", String(!abierto));
		});
	});

	document.querySelectorAll(".rating-input").forEach((btn) => {
		btn.addEventListener("click", () => {
			const valorSeleccionado = parseInt(btn.dataset.value);
			document.getElementById("calificacion").value = valorSeleccionado;

			document.querySelectorAll(".rating-input").forEach((input) => {
				input.checked = parseInt(input.dataset.value) <= valorSeleccionado;
			});
		});
	});

	const URL_API = "https://limited-cathy-peru-luxury-54ebd510.koyeb.app/evaluacion";
	const form = document.querySelector(".form-contacto");

	const mapCalificacion = (valor) => {
		const notas = {
			"4": "Excelente",
			"3": "Bueno",
			"2": "Regular",
			"1": "Malo",
		};
		return notas[valor] || null;
	};

	form?.addEventListener("submit", async (e) => {
		e.preventDefault();

		const btn = form.querySelector("button[type='submit']");
		btn.disabled = true;
		btn.innerText = "Enviando...";

		const formData = new FormData(form);

		const restaurantes = [];
		for (let i = 1; i <= 4; i++) {
			const nombre = formData.get(`rest-nombre-${i}`);
			const ubi    = formData.get(`rest-ubicacion-${i}`);
			const cal    = formData.get(`rest-calif-${i}`);
			if (nombre || ubi || cal) {
				restaurantes.push({
					restaurante_name:          nombre || "N/A",
					restaurante_ubicacion:     ubi    || "N/A",
					restaurante_calificacion:  mapCalificacion(cal) || "No evaluado",
				});
			}
		}

		const data = {
			nombre:       formData.get("nombre"),
			email:        formData.get("email"),
			fecha:        formData.get("fecha"),
			comentarioHotelTransfer: formData.get("comentarioHotelTransfer"),
			comentarioHotel: formData.get("comentarioHotel"),
			comentarioRestaurante: formData.get("comentarioRestaurante"),
			comentariosToursGuia: formData.get("comentarioToursGuia"),
			calificacion: parseInt(document.getElementById("calificacion").value) || 0,

			hotelTransfer: [
				{ hotelTransfer_name: "Lima",         hotelTransfer_calificacion: mapCalificacion(formData.get("transfer-lima"))     },
				{ hotelTransfer_name: "Cusco",        hotelTransfer_calificacion: mapCalificacion(formData.get("transfer-cusco"))    },
				{ hotelTransfer_name: "Valle Sagrado",hotelTransfer_calificacion: mapCalificacion(formData.get("transfer-valle"))    },
				{ hotelTransfer_name: "Servicio de Tren a Machu Picchu",     hotelTransfer_calificacion: mapCalificacion(formData.get("transfer-arequipa")) },
				
				{ hotelTransfer_name: formData.get("hotel-transfer-nombre-1"),     hotelTransfer_calificacion: mapCalificacion(formData.get("hotel-transfer-calificacion-1")) },
				{ hotelTransfer_name: formData.get("hotel-transfer-nombre-2"),     hotelTransfer_calificacion: mapCalificacion(formData.get("hotel-transfer-calificacion-2")) },
				{ hotelTransfer_name: formData.get("hotel-transfer-nombre-3"),     hotelTransfer_calificacion: mapCalificacion(formData.get("hotel-transfer-calificacion-3")) },
				{ hotelTransfer_name: formData.get("hotel-transfer-nombre-4"),     hotelTransfer_calificacion: mapCalificacion(formData.get("hotel-transfer-calificacion-4")) },
			].filter((i) => i.hotelTransfer_calificacion),

			tours: [
				{ tours_name: "Recorrido por la ciudad de Lima", tours_calificacion: mapCalificacion(formData.get("guia-lima"))  },
				{ tours_name: "Recorrido por la ciudad de Lima y museo", tours_calificacion: mapCalificacion(formData.get("guia-lima-museo")) },
				{ tours_name: "Tour por la ciudad de Cusco",tours_calificacion: mapCalificacion(formData.get("guia-ciudad-cusco")) },
				{ tours_name: "Pisac y Ollantaytambo",tours_calificacion: mapCalificacion(formData.get("guia-pisac")) },
				{ tours_name: "Piscinas salinas de Moray y Maras",tours_calificacion: mapCalificacion(formData.get("guia-piscinas-moray")) },
				{ tours_name: "Excursión a Machu Picchu",tours_calificacion: mapCalificacion(formData.get("guia-machu-picchu")) },
				
				
				{ tours_name: formData.get("tours-nombre-1"),tours_calificacion: mapCalificacion(formData.get("tours-guia-1")) },
				{ tours_name: formData.get("tours-nombre-2"),tours_calificacion: mapCalificacion(formData.get("tours-guia-2")) },
				{ tours_name: formData.get("tours-nombre-3"),tours_calificacion: mapCalificacion(formData.get("tours-guia-3")) },
				{ tours_name: formData.get("tours-nombre-4"),tours_calificacion: mapCalificacion(formData.get("tours-guia-4")) },
			].filter((i) => i.tours_calificacion),

			hotel: [
				{ hotel_ubicacion: "Lima",  hotel_name: formData.get("hotel-lima"), hotel_calificacion: mapCalificacion(formData.get("hotel-lima-calificacion"))  },
				{ hotel_ubicacion: "Cusco", hotel_name: formData.get("hotel-cusco"), hotel_calificacion: mapCalificacion(formData.get("hotel-cusco-calificacion")) },
				{ hotel_ubicacion: "Machu Picchu", hotel_name: formData.get("hotel-machu-picchu"), hotel_calificacion: mapCalificacion(formData.get("hotel-machu-picchu-calificacion")) },
				{ hotel_ubicacion: "Valle Sagrado", hotel_name: formData.get("hotel-valle-sagrado"), hotel_calificacion: mapCalificacion(formData.get("hotel-valle-sagrado-calificacion")) },

				{ hotel_ubicacion: formData.get("hotel-ubicacion-1"), hotel_name: formData.get("hotel-nombre-1"), hotel_calificacion: mapCalificacion(formData.get("hotel-calificacion-1")) },
				{ hotel_ubicacion: formData.get("hotel-ubicacion-2"), hotel_name: formData.get("hotel-nombre-2"), hotel_calificacion: mapCalificacion(formData.get("hotel-calificacion-2")) },
				{ hotel_ubicacion: formData.get("hotel-ubicacion-3"), hotel_name: formData.get("hotel-nombre-3"), hotel_calificacion: mapCalificacion(formData.get("hotel-calificacion-3")) },
				{ hotel_ubicacion: formData.get("hotel-ubicacion-4"), hotel_name: formData.get("hotel-nombre-4"), hotel_calificacion: mapCalificacion(formData.get("hotel-calificacion-4")) },


			].filter((i) => i.hotel_calificacion),

			restaurantes: restaurantes,
			comentario:   formData.get("comentarios") || "",
		};

		try {
			const response = await fetch(URL_API, {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify(data),
			});

			if (response.ok) {
				Swal.fire({
					title: '¡Éxito!',
					text: 'Evaluación enviada con éxito.',
					icon: 'success',
					confirmButtonText: 'Cerrar'
				})
				form.reset();
				document.getElementById("calificacion").value = "0";
			} else {
				Swal.fire({
					title: 'Error!',
					text: 'Error al enviar. Inténtalo de nuevo.',
					icon: 'error',
					confirmButtonText: 'Cerrar'
				})
			}
		} catch (error) {
			console.error("Error:", error);
			alert("Error de conexión con el servidor.");
		} finally {
			btn.innerText = "Enviar evaluación →";
			btn.disabled = false;
		}
	});
</script>

