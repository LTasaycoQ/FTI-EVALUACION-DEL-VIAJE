				restaurante: "Nombre Restaurante",
				experiencia: "Cuéntenos su experiencia...",
			},
			header: {
				calificacion: "Calificación",
				malo:         "Malo",
				regular:      "Regular",
				bueno:        "Bueno",
				excelente:    "Excelente",
			},
			secciones: {
				titulos: {
					transfer:     "Hotel Transfer",
