<script is:inline>
  const URL = "https://sturdy-waffle-7g9rv6vgq5g2r7xg-8000.app.github.dev/evaluacion";
  const form = document.querySelector(".form-contacto");
  
  const mapCalificacion = (valor) => {
    const notas = {
      "1": "Excelente",
      "2": "Bueno",
      "3": "Regular",
      "4": "Malo"
    };
    return notas[valor] || "No evaluado";
  };

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const btn = form.querySelector("button[type='submit']");
    btn.disabled = true;

    btn.innerText = "Enviando...";
    
    const formData = new FormData(form);

    const restaurantes = [];
    for (let i = 1; i <= 4; i++) {
      const nombre = formData.get(`rest-nombre-${i}`);
      const ubicacion = formData.get(`rest-ubicacion-${i}`);
      const calif = formData.get(`rest-calif-${i}`);
      
      if (nombre || ubicacion) { 
        restaurantes.push({
          restaurante_ubicacion: ubicacion || "",
          restaurante_name: nombre || "",
          restaurante_calificacion: mapCalificacion(calif)
        });
      }
    }

    const data = {
      nombre: formData.get("nombre"),
      email: formData.get("email"),
      fecha: formData.get("fecha"),
      calificacion: parseInt(document.getElementById("calificacion").value) || 0,
      hotelTransfer: [
        { hotelTransfer_name: "lima", hotelTransfer_calificacion: mapCalificacion(formData.get("transfer-lima")) },
        { hotelTransfer_name: "cusco", hotelTransfer_calificacion: mapCalificacion(formData.get("transfer-cusco")) },
        { hotelTransfer_name: "valle sagrado", hotelTransfer_calificacion: mapCalificacion(formData.get("transfer-valle")) },
        { hotelTransfer_name: "arequipa", hotelTransfer_calificacion: mapCalificacion(formData.get("transfer-arequipa")) }
      ],
      tours: [
        { tours_name: "lima", tours_calificacion: mapCalificacion(formData.get("guia-lima")) },
        { tours_name: "cusco", tours_calificacion: mapCalificacion(formData.get("guia-cusco")) },
        { tours_name: "machu picchu", tours_calificacion: mapCalificacion(formData.get("guia-machu")) },
        { tours_name: "valle sagrado", tours_calificacion: mapCalificacion(formData.get("guia-valle")) }
      ],
      hotel: [
        { hotel_name: "lima", hotel_calificacion: mapCalificacion(formData.get("hotel-lima")) },
        { hotel_name: "cusco", hotel_calificacion: mapCalificacion(formData.get("hotel-cusco")) },
        { hotel_name: "machu picchu", hotel_calificacion: mapCalificacion(formData.get("hotel-aguas")) }
      ],
      restaurantes: restaurantes,
      comentario: formData.get("comentarios")
    };
    
    
    try {
      const response = await fetch(URL, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });
      
      if (response.ok) {
        console.log("Éxito:", data);
        alert("Evaluación enviada correctamente");
        form.reset();
        document.getElementById("calificacion").value = "0";
      } else {
        console.error("Error en servidor:", response.status);
      }
    } catch (error) {
      console.error("Error de red:", error);
    } finally {
      btn.innerText = "Enviar evaluación →";
      btn.disabled = false;
    }
  });
</script>

<script is:inline>
	document.querySelectorAll(".seccion-header").forEach((btn) => {
		btn.addEventListener("click", () => {
			const cuerpo = btn.nextElementSibling;
			const abierto = cuerpo.classList.contains("abierto");
			cuerpo.classList.toggle("abierto", !abierto);
			btn.setAttribute("aria-expanded", String(!abierto));
		});
	});
</script>

<style>

	.container-input_resturante{
		display: flex;
		gap: 10px;
