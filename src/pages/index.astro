		gap: 20px;
		margin-bottom: 30px;
	}
	

	.datosForm-personal{
		height: 40px;
		padding: 20px;
		border-radius: 20px;
		width: 100%;
		outline: none;
		color: rgb(63, 63, 63);
	}
	.container-datosUnico{
		display: flex;
		width: 100%;
		align-items: center;
		gap: 10px;
		i{
			font-size: 20px;
			background-color: #195d40;
			border-radius: 50px;
			padding: 8px 10px 8px 10px;
			color: white;
		}
		
	}
 .input-radioValoracion {
        display: flex;
        justify-content: space-between;
        gap: 4px;
        background: #f8fafc;
        padding: 8px;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
    }

    .rating-input {
        appearance: none;
        -webkit-appearance: none;
        width: 60px;
        height: 60px;
        border-radius: 5px;
        background-color: white;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
        position: relative;
        border: 1px solid #cbd5e1;
    }

	.rating-input::before {
		content: "\f586"; 
		font-family: "bootstrap-icons";
		font-size: 1rem;
		font-style: normal;
		font-weight: normal;
		font-variant: normal;
		text-transform: none;
		line-height: 1;
		vertical-align: middle;
		display: inline-block;
	}
    .rating-input:hover {
        transform: scale(1.1);
        z-index: 10;
        border-color: #3b82f6;
    }


    .rating-input:checked {
        background-color: #105a40;
        border-color: #85eb25;
        transform: scale(1.15);
        box-shadow: 0 4px 10px rgba(59, 130, 246, 0.3);
    }

    .rating-input:checked::before {
        color: white;
    }

    .rating-input[value="9"]:checked,
    .rating-input[value="10"]:checked {
        background-color: #084c21;
        border-color: #1a6636;
        box-shadow: 0 4px 10px rgb(28, 114, 84);
    }


	@media (width < 48rem) { 

		.container-datos{
			flex-direction: column;
		}
	 }
</style>

