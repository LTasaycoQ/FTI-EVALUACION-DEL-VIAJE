<script is:inline>
	document.querySelectorAll(".seccion-header").forEach((btn) => {
		btn.addEventListener("click", () => {
			const cuerpo = btn.nextElementSibling;
			const abierto = cuerpo.classList.contains("abierto");
			cuerpo.classList.toggle("abierto", !abierto);
			btn.setAttribute("aria-expanded", String(!abierto));
		});
	});

	document.querySelectorAll(".rating-input").forEach((btn) => {
		btn.addEventListener("click", () => {
			const valorSeleccionado = parseInt(btn.dataset.value);
			document.getElementById("calificacion").value = valorSeleccionado;

			document.querySelectorAll(".rating-input").forEach((input) => {
				input.checked = parseInt(input.dataset.value) <= valorSeleccionado;
			});
		});
	});

	const URL_API = "https://sturdy-waffle-7g9rv6vgq5g2r7xg-8000.app.github.dev/evaluacion";
	const form = document.querySelector(".form-contacto");

	const mapCalificacion = (valor) => {
		const notas = {
			"1": "Excelente",
			"2": "Bueno",
			"3": "Regular",
			"4": "Malo",
		};
		return notas[valor] || null;
	};

	form?.addEventListener("submit", async (e) => {
		e.preventDefault();

		const btn = form.querySelector("button[type='submit']");
		btn.disabled = true;
		btn.innerText = "Enviando...";

		const formData = new FormData(form);

		const restaurantes = [];
		for (let i = 1; i <= 4; i++) {
			const nombre = formData.get(`rest-nombre-${i}`);
			const ubi    = formData.get(`rest-ubicacion-${i}`);
			const cal    = formData.get(`rest-calif-${i}`);
			if (nombre || ubi || cal) {
				restaurantes.push({
					restaurante_name:          nombre || "N/A",
					restaurante_ubicacion:     ubi    || "N/A",
					restaurante_calificacion:  mapCalificacion(cal) || "No evaluado",
				});
			}
		}

		const data = {
			nombre:       formData.get("nombre"),
			email:        formData.get("email"),
			fecha:        formData.get("fecha"),
			calificacion: parseInt(document.getElementById("calificacion").value) || 0,

			hotelTransfer: [
				{ hotelTransfer_name: "Lima",         hotelTransfer_calificacion: mapCalificacion(formData.get("transfer-lima"))     },
				{ hotelTransfer_name: "Cusco",        hotelTransfer_calificacion: mapCalificacion(formData.get("transfer-cusco"))    },
				{ hotelTransfer_name: "Valle Sagrado",hotelTransfer_calificacion: mapCalificacion(formData.get("transfer-valle"))    },
				{ hotelTransfer_name: "Arequipa",     hotelTransfer_calificacion: mapCalificacion(formData.get("transfer-arequipa")) },
			].filter((i) => i.hotelTransfer_calificacion),

			tours: [
				{ tours_name: "Recorrido por la ciudad de Lima", tours_calificacion: mapCalificacion(formData.get("guia-lima"))  },
				{ tours_name: "Recorrido por la ciudad de Lima y museo", tours_calificacion: mapCalificacion(formData.get("guia-lima-museo")) },
				{ tours_name: "Tour por la ciudad de Cusco",tours_calificacion: mapCalificacion(formData.get("guia-ciudad-cusco")) },
				{ tours_name: "Pisac y Ollantaytambo",tours_calificacion: mapCalificacion(formData.get("guia-pisac")) },
				{ tours_name: "Piscinas salinas de Moray y Maras",tours_calificacion: mapCalificacion(formData.get("guia-piscinas-moray")) },
				{ tours_name: "Excursión a Machu Picchu",tours_calificacion: mapCalificacion(formData.get("guia-machu-picchu")) },
			].filter((i) => i.tours_calificacion),

			hotel: [
				{ hotel_name: "Lima",  hotel_calificacion: mapCalificacion(formData.get("hotel-lima"))  },
				{ hotel_name: "Cusco", hotel_calificacion: mapCalificacion(formData.get("hotel-cusco")) },
			].filter((i) => i.hotel_calificacion),

			restaurantes: restaurantes,
			comentario:   formData.get("comentarios") || "",
		};

		try {
			const response = await fetch(URL_API, {
				method: "POST",
				headers: { "Content-Type": "application/json" },
				body: JSON.stringify(data),
			});

			if (response.ok) {
				alert("Evaluación enviada con éxito.");
				form.reset();
				document.getElementById("calificacion").value = "0";
			} else {
				alert("Error al enviar. Inténtalo de nuevo.");
			}
		} catch (error) {
			console.error("Error:", error);
			alert("Error de conexión con el servidor.");
		} finally {
			btn.innerText = "Enviar evaluación →";
			btn.disabled = false;
		}
	});
</script>

