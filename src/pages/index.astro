	function applyLang(lang) {
		console.log("Aplicando idioma:", lang);
		const t = translations[lang] || translations.es;
		const p = t.placeholders;

		const h1 = document.querySelector(".hero h1");
		if (h1) h1.textContent = t.titulo;

		const btnEnviar = document.querySelector(".btn-enviar");
		if (btnEnviar) btnEnviar.textContent = t.enviar;

		document.querySelectorAll(".comentarioText").forEach((el) => {
			el.textContent = el.closest(".seccion-comentarios")
				? t.comentariosGenerales
				: t.comentario;
		});

		const recomendarEl = document.querySelector(".max-w-xl p");
		if (recomendarEl) recomendarEl.textContent = t.recomendar;

		const footerNote = document.querySelector(".footer-note");
		if (footerNote) footerNote.textContent = t.agradecimiento;

		document.querySelectorAll("[data-i18n]").forEach((el) => {
			const key = el.getAttribute("data-i18n");
			if (t.header[key]) el.textContent = t.header[key];
		});

		document.querySelectorAll("[data-i18n-seccion]").forEach((el) => {
			const key            = el.getAttribute("data-i18n-seccion");
			const [grupo, id]    = key.split(".");
			const texto          = t.secciones?.[grupo]?.[id];
			if (texto) el.textContent = texto;
		});

		const set = (selector, value) =>
			document.querySelectorAll(selector).forEach((el) => (el.placeholder = value));

		set("input[name='nombre']",                    p.nombre);
		set("input[name='email']",                     p.email);
		set(".input-hotel-transfer",                   p.ciudad);
		set(".input-restaurante[name*='hotel']",       p.hotel);
		set(".input-restaurante[name*='ubicacion']",   p.ubicacion);
		set(".input-restaurante[name*='nombre']",      p.hotel);
		set("input[name*='rest-nombre']",              p.restaurante);
		set("input[name*='rest-ubicacion']",           p.ubicacion);
		set("textarea[name='comentarios']",            p.experiencia);
	}

	const savedLang = localStorage.getItem("lang") || "es";
	applyLang(savedLang);

	window.addEventListener("changeLang", (e) => {
		applyLang(e.detail);
	});
