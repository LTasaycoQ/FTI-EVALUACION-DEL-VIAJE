---
import BaseLayout from "../Layout/BaseLayout.astro";
import HeaderTable from "../components/headerTable.astro";
import "../styles/formEvaluacion.css";

const evaluationData = {
    "hotelTransfer": [
        { "id": "transfer-lima", "label": "Lima" },
        { "id": "transfer-cusco", "label": "Cusco" },
        { "id": "transfer-valle", "label": "Valle Sagrado" },
        { "id": "transfer-arequipa", "label": "Arequipa" }
    ],
    "tours": [
        { "id": "guia-lima", "label": "Tour a la ciudad de Lima" },
        { "id": "guia-museo", "label": "Tour a la ciudad de Lima & museo" },
        { "id": "guia-cusco", "label": "Tour a la ciudad de Cusco" },
        { "id": "guia-vallesagrado", "label": "Pisac & Ollantaytambo" },
        { "id": "guia-machu", "label": "Excursión a Machu Picchu" }
    ],
    "hoteles": [
        { "id": "hotel-lima", "label": "Lima" },
        { "id": "hotel-cusco", "label": "Cusco" },
        { "id": "hotel-machu", "label": "Machu Picchu" },
        { "id": "hotel-valle", "label": "Valle Sagrado" }
    ]
};
---

<BaseLayout title="Evaluación de Viaje">
    <main>
        <section class="containerEvaluacionViaje">
            <div class="hero">
                <h1>EVALUACIÓN DEL VIAJE</h1>
                <div class="hero-line"></div>
            </div>

            <div class="intro-card">
                <p>
                    <strong>Estimado Visitante,</strong> <br> Lo invitamos a que nos dé su opinión sobre nuestros servicios. Por favor, ayúdenos a identificar a nuestros colaboradores que vienen desarrollando una labor de excelencia para premiarlos y/o detectar en qué áreas debemos mejorar. Buscamos perfeccionar el arte de <span class="text-parrafo">“atender al turista”</span>
                </p>
            </div>

            <div class="containerForm">
                <form class="form-contacto">
                    <div class="container-datos">
                        <div class="container-datosUnico">
                            <i class="bi bi-person-fill"></i>
                            <input class="datosForm-personal" type="text" name="nombre" placeholder="Nombre completo" required>
                        </div>
                        <div class="container-datosUnico">
                            <i class="bi bi-calendar-date"></i>
                            <input class="datosForm-personal" type="date" name="fecha" required>
                        </div>
                    </div>

                    {Object.entries(evaluationData).map(([key, items]) => (
                        <div class="seccion">
                            <button type="button" class="seccion-header" aria-expanded={key === 'hotelTransfer' ? "true" : "false"}>
                                <div class="seccion-titulo">
                                    <span>{key.replace(/([A-Z])/g, ' $1').toUpperCase()}</span>
                                </div>
                                <span class="chevron"><i class="bi bi-arrow-down-circle-fill"></i></span>
                            </button>
                            <div class={`seccion-cuerpo ${key === 'hotelTransfer' ? 'abierto' : ''}`}>
                                <table>
                                    <HeaderTable />
                                    <tbody>
                                        {items.map((item) => (
                                            <tr>
                                                <td class="fila-label">{item.label}</td>
                                                {[1, 2, 3, 4].map((v) => (
                                                    <td><input type="radio" name={item.id} value={v} required /></td>
                                                ))}
                                            </tr>
                                        ))}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    ))}

                    <div class="seccion">
                        <button type="button" class="seccion-header">
                            <div class="seccion-titulo"><span>Comentarios Generales</span></div>
                            <span class="chevron"><i class="bi bi-arrow-down-circle-fill"></i></span>
                        </button>
                        <div class="seccion-cuerpo">
                            <div class="comentarios-wrap">
                                <textarea name="comentario" rows="5" placeholder="Cuéntenos su experiencia..."></textarea>
                            </div>
                        </div>
                    </div>

                    <div class="nps-container">
                        <p class="text-center font-bold">¿Qué tan probable es que recomiendes nuestro servicio?</p>
                        <div class="input-radioValoracion">
                            {[...Array(10)].map((_, i) => (
                                <input type="checkbox" name="nps_step" value={i + 1} data-value={i + 1} class="rating-input" />
                            ))}
                        </div>
                        <input type="hidden" id="calificacion_final" name="calificacion_nps" value="0">
                    </div>

                    <div class="form-footer">
                        <p class="footer-note">Gracias por ayudarnos a mejorar.</p>
                        <button type="submit" class="btn-enviar">Enviar evaluación →</button>
                    </div>
                </form>
            </div>
        </section>
    </main>
</BaseLayout>

<script is:inline>
    document.querySelectorAll(".seccion-header").forEach((btn) => {
        btn.addEventListener("click", () => {
            const cuerpo = btn.nextElementSibling;
            const isAbierto = cuerpo.classList.contains("abierto");
            cuerpo.classList.toggle("abierto", !isAbierto);
            btn.setAttribute("aria-expanded", !isAbierto);
        });
    });

    const ratingInputs = document.querySelectorAll(".rating-input");
    const inputHidden = document.getElementById("calificacion_final");

    ratingInputs.forEach((btn) => {
        btn.addEventListener("click", () => {
            const val = parseInt(btn.dataset.value);
            inputHidden.value = val;
            ratingInputs.forEach((input, index) => {
                input.checked = index < val;
            });
        });
    });

    const FORM_URL = "https://sturdy-waffle-7g9rv6vgq5g2r7xg-8000.app.github.dev/evaluacion";
    const form = document.querySelector(".form-contacto");

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const btnSubmit = form.querySelector(".btn-enviar");
        btnSubmit.disabled = true;
        btnSubmit.innerText = "Enviando...";

        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());
			console.log("Evaluación enviada:", JSON.stringify(data));

        try {
            await fetch(FORM_URL, {
                method: "POST",
                mode: "no-cors", 
                body: JSON.stringify(data),
            });

           conso.log("Evaluación enviada:", data);
            form.reset();
        } catch (error) {
            console.log("Error al enviar evaluación:", error);
        } finally {
            btnSubmit.disabled = false;
            btnSubmit.innerText = "Enviar evaluación →";
        }
    });
</script>

