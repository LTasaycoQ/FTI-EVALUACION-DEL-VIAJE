							<div class="seccion-titulo">
								<span data-i18n-seccion="titulos.transfer">Hotel Transfer</span>
							</div>
							<span class="chevron"><i class="bi bi-arrow-down-circle-fill"></i></span>
						</button>
						<div class="seccion-cuerpo abierto">
							<table>
								<HeaderTable />
								<tbody>
									<tr>
										<td class="fila-label">Lima</td>
										<td><input type="radio" name="transfer-lima" value="1" /></td>
										<td><input type="radio" name="transfer-lima" value="2" /></td>
										<td><input type="radio" name="transfer-lima" value="3" /></td>
										<td><input type="radio" name="transfer-lima" value="4" /></td>
									</tr>
									<tr>
										<td class="fila-label">Cusco</td>
