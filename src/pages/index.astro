								const valorSeleccionado = Math.floor(btn.dataset.value);
								console.log(`Calificación seleccionada: ${valorSeleccionado} estrellas`);

								const inputCalificacion = document.getElementById("calificacion");
								inputCalificacion.value = valorSeleccionado;

								
								for (let i = 1; i <= valorSeleccionado; i++) {
									
									const input = document.querySelector(`.rating-input[data-value="${i}"]`);
									input.checked = true;								
									console.log(`Estrella ${i} marcada como seleccionada`);
								}
