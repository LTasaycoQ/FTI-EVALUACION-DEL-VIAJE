---
import BaseLayout from "../Layout/BaseLayout.astro";
import HeaderTable from "../components/headerTable.astro";
---

<BaseLayout>
	<main>
		<section class="containerEvaluacionViaje">

			<!-- ── HERO ── -->
			<div class="hero">
				<h1>EVALUACIÓN DEL VIAJE</h1>
				<div class="hero-line"></div>
			</div>

			<!-- ── INTRO ── -->
			<div class="intro-card">
				<p>
					<strong>Estimado Visitante,</strong> lo invitamos a que nos dé
					su opinión sobre nuestros servicios. Por favor, ayúdenos a identificar
					a nuestros colaboradores que vienen desarrollando una labor de
					excelencia para premiarlos y detectar en qué áreas debemos mejorar.
					Buscamos perfeccionar el arte de <em>atender al turista</em>.
				</p>
			</div>

			<!-- ── FORMULARIO ── -->
			<div class="containerForm">
				<form class="form-contacto">

					<!-- Datos personales -->
					<div class="container-datos">
						<div class="container-datosUnico">
							<i class="bi bi-person-fill"></i>
							<input
								class="datosForm-personal"
								type="text"
								name="nombre"
								placeholder="Nombre completo"
								required
							/>
						</div>
						<div class="container-datosUnico">
							<i class="bi bi-calendar-date"></i>
							<input
								class="datosForm-personal"
								type="date"
								name="fecha"
								placeholder="Fecha"
								required
							/>
						</div>
					</div>

					<div class="container-datosUnico mb-8">
						<i class="bi bi-envelope-at-fill"></i>
						<input
							class="datosForm-personal"
							type="email"
							name="email"
							placeholder="Correo electrónico"
							required
						/>
					</div>

					<!-- ── SECCIÓN: Hotel Transfer ── -->
					<div class="seccion">
						<button type="button" class="seccion-header" aria-expanded="true">
							<div class="seccion-titulo">
								<span>Hotel Transfer</span>
							</div>
							<span class="chevron">
								<i class="bi bi-arrow-down-circle-fill"></i>
							</span>
						</button>
						<div class="seccion-cuerpo abierto">
