									</tr>


									<tr>
										<td class="fila-label">
											<div class="container-input_hotel">
												<input class="hotel_input input-restaurante" type="text" name="ubicacion1"  placeholder="Nombre Restaurante" />
												<input class="hotel_input input-restaurante" type="text" name="rest-nombre-1" placeholder="Nombre Restaurante" />
											</div>
										</td>
										<td><input type="radio" name="hotel-machu-picchu" value="1" /></td>
										<td><input type="radio" name="hotel-machu-picchu" value="2" /></td>
										<td><input type="radio" name="hotel-machu-picchu" value="3" /></td>
										<td><input type="radio" name="hotel-machu-picchu" value="4" /></td>
									</tr>

									<tr>
										<td class="fila-label">
											<div class="container-input_hotel">
												<input class="hotel_input input-restaurante" type="text" name="ubicacion1"  placeholder="Nombre Restaurante" />
												<input class="hotel_input input-restaurante" type="text" name="rest-nombre-1" placeholder="Nombre Restaurante" />
											</div>
										</td>
										<td><input type="radio" name="hotel-valle-sagrado" value="1" /></td>
