					<div class="seccion">
						<button type="button" class="seccion-header" aria-expanded="false">
							<div class="seccion-titulo">
								<span>Restaurantes</span>
							</div>
							<span class="chevron">
								<i class="bi bi-arrow-down-circle-fill"></i>
							</span>
						</button>
						<div class="seccion-cuerpo">
							<table>
								<HeaderTable />
								<tbody>
									<tr>
										<td class="fila-label">
											<div class="container-input_resturante">
