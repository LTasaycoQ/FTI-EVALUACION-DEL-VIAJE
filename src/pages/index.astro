				},
			},
		},
		en: {
			titulo:               "TRIP EVALUATION",
			comentario:           "Comment",
			comentariosGenerales: "General Comments and/or Suggestions",
			recomendar:           "How likely are you to recommend our service?",
			agradecimiento:       "Thank you sincerely for filling out our evaluation form",
			enviar:               "Send evaluation →",
			placeholders: {
				nombre:      "Full name",
